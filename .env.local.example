# Expense Reports — Gmail receipt matching (Phase 2)
# Dedicated Google OAuth client with the gmail.readonly scope (separate from login).
GOOGLE_RECEIPT_CLIENT_ID=
GOOGLE_RECEIPT_CLIENT_SECRET=
GOOGLE_RECEIPT_REDIRECT_URI=http://localhost:3000/api/expenses/accounts/callback
# Optional: base64-encoded 32 bytes used to encrypt stored Gmail refresh tokens.
# If unset, a key is derived from NEXTAUTH_SECRET. Generate: openssl rand -base64 32
RECEIPT_TOKEN_KEY=
